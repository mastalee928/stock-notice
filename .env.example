# 店铺 API 根地址（不要以 / 结尾），例如 https://masta.ee
SITE_URL=https://masta.ee

# Telegram Bot Token（由 @BotFather 创建）
TELEGRAM_BOT_TOKEN=

# Telegram 频道/群组 ID（发到这里），例如 -1001234567890
TELEGRAM_CHAT_ID=

# 轮询间隔（秒），默认 5；仅库存变化时发送通知
INTERVAL_SECONDS=5

# 首次运行也发一条「当前库存」（便于确认 Bot 正常），建议首次部署时保留 1
NOTIFY_ON_FIRST_RUN=1

# 通知文案（可选，不设则用代码内默认值）
NOTIFY_HEADER=masta.ee 通知
NOTIFY_FIRST_TITLE=当前库存
NOTIFY_CHANGE_TITLE=检测到库存变化
NOTIFY_SUBTITLE=当前库存为
